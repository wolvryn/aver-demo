# aver-demo — environment variables
#
# Copy to .env.local and fill in real values. .env.local is never committed.
# Each variable is classified: SECRET (server-only credential, fail loudly if missing),
# CONFIG (non-secret setting), or PUBLIC (safe to ship in the client bundle).
# No NEXT_PUBLIC_* var may ever carry a server secret or the Aver endpoint.

# ─── Live generation (model provider) ────────────────────────────────────────
# SECRET — Anthropic API key for live agent generation. Server-only.
ANTHROPIC_API_KEY=sk-ant-replace-me

# ─── Finnhub (live stock-quote source for the demo pipeline) ─────────────────
# SECRET — Finnhub API key for the source-collection seam's live quote fetches. Server-only;
# never exposed to the browser. Free tier is 60 requests/minute.
FINNHUB_API_KEY=replace-with-finnhub-api-key

# ─── Aver service (private detection service, invoked server-side over HTTP) ──
# CONFIG — base URL of the deployed Aver service. Server-only; never exposed to the browser.
AVER_SERVICE_URL=https://aver.internal.example.com
# SECRET — bearer token used to authenticate to the Aver service. Server-only.
AVER_SERVICE_TOKEN=replace-with-aver-service-token

# ─── Logging ─────────────────────────────────────────────────────────────────
# CONFIG — minimum level the centralized logger emits: error | warn | info | debug.
# Defaults to 'info' when unset or unrecognized. Never 'debug' in production.
LOG_LEVEL=info

# ─── Error tracking (Sentry) ─────────────────────────────────────────────────
# CONFIG — Sentry DSN. Public-safe by design (ships in the client bundle); contains no secret.
# Error tracking degrades gracefully (no-ops) when unset.
NEXT_PUBLIC_SENTRY_DSN=
